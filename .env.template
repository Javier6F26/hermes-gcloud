# ──────────────────────────────────────────────
# Hermes — Configuración mínima (1 vez)
# Copia este archivo como .env y completa
# ──────────────────────────────────────────────

# === API KEYS (obligatorio al menos una) ===
# Descomenta al menos una:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-proj-...
# OPENROUTER_API_KEY=sk-or-...

# === TELEGRAM / DISCORD (opcional) ===
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# === Git identity (opcional — para commits desde el sandbox) ===
# GIT_USER_NAME=Tu Nombre
# GIT_USER_EMAIL=tu@email.com

# === SSH deploy key (opcional — para clonar repos privados) ===
# Pega la clave privada COMPLETA (incluyendo BEGIN/END lines)
# SSH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----
# ...
# SSH_PUBLIC_KEY=ssh-ed25519 AAAAC3... tu@host

# === GCP service account (opcional — salta gcloud auth login manual) ===
# Pega el JSON COMPLETO de la service account key en una línea
# GCLOUD_SERVICE_ACCOUNT_KEY={"type": "service_account", ...}
